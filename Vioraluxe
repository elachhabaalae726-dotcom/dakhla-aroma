  { brand: "CHANEL", name: "Coco Mademoiselle", cat: "soir" },
  { brand: "KAYALI", name: "Vanille 21", cat: "gourmand" },
  { brand: "KAYALI", name: "Marshmallow", cat: "gourmand" },
  { brand: "DOLCE&GABBANA", name: "Light Blue", cat: "frais" },
  { brand: "DIOR", name: "L'imperatrice", cat: "frais" },
  { brand: "ESCADA", name: "Taj Sunset", cat: "frais" },
  { brand: "CHANEL", name: "Chance", cat: "floral" },
  { brand: "LATTAFA", name: "Yara", cat: "gourmand" },
  { brand: "LANCOME", name: "La Vie Est Belle", cat: "gourmand" },
  { brand: "CAROLINA HERRERA", name: "Good Girl", cat: "soir" },
  { brand: "GIORGIO ARMANI", name: "My Way", cat: "floral" },
  { brand: "YVES SAINT LAURENT", name: "Libre", cat: "soir" },
  { brand: "JEAN PAUL GAULTIER", name: "Scandal", cat: "gourmand" },
  { brand: "YVES SAINT LAURENT", name: "Black Opium", cat: "soir" },
  { brand: "GIORGIO ARMANI", name: "Si", cat: "floral" },
  { brand: "PARFUMS DE MARLY", name: "Delina", cat: "floral" },
  { brand: "", name: "Eclaire", cat: "frais" }
];

const WA_BASE = "https://wa.me/212728339347?text=";

function waLink(brand, name, size, price) {
  const brandPart = brand ? brand + " - " : "";
  const msg = `Bonjour VioraLuxe, je souhaite commander ${brandPart}${name} - ${size} - ${price} DH.`;
  return WA_BASE + encodeURIComponent(msg);
}

const grid = document.getElementById('fragranceGrid');

function renderPerfumes(filter = 'all') {
  const items = filter === 'all' ? PERFUMES : PERFUMES.filter(p => p.cat === filter);
  grid.innerHTML = items.map(p => `
    <article class="f-card" data-cat="${p.cat}">
      <div class="f-brand">${p.brand || "VIORALUXE"}</div>
      <h3 class="f-name">${p.name}</h3>
      <div class="f-sizes">
        <a class="size-btn" href="${waLink(p.brand, p.name, "30 ml", "60")}" target="_blank" rel="noopener">
          30 ml<br><small>60 DH</small>
        </a>
        <a class="size-btn strong" href="${waLink(p.brand, p.name, "50 ml", "99")}" target="_blank" rel="noopener">
          50 ml<br><small>99 DH</small>
        </a>
      </div>
    </article>
  `).join('');
}
renderPerfumes();

// Filters
document.getElementById('filterRow').addEventListener('click', (e) => {
  const btn = e.target.closest('.filter-btn');
  if(!btn) return;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderPerfumes(btn.dataset.filter);
});

// Mobile menu
const menuToggle = document.getElementById('menuToggle');
const mobileNav = document.getElementById('mobileNav');
menuToggle.addEventListener('click', () => {
  const open = mobileNav.classList.toggle('open');
  menuToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
});
mobileNav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
  mobileNav.classList.remove('open');
  menuToggle.setAttribute('aria-expanded', 'false');
}));

// Close mobile nav on resize up
window.addEventListener('resize', () => {
  if(window.innerWidth > 720 && mobileNav.classList.contains('open')){
    mobileNav.classList.remove('open');
    menuToggle.setAttribute('aria-expanded', 'false');
  }
});
</script>
